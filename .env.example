# ──────────────────────────────────────────────
# Frontend (Vite) — prefix with VITE_ so it reaches the browser.
# Only these are actually read by this React app.
# ──────────────────────────────────────────────

# Active chain id. 11142220 = Celo Sepolia, 42220 = Celo Mainnet.
VITE_CHAIN_ID=11142220

# Base URL of the PayLink backend (Bun + Hono). Unlocks AI copilot,
# IPFS metadata pinning, phone-number resolution, PDF, x402 and
# the cron digest button. Leave blank to run fully on-chain / offline.
VITE_BACKEND_URL=https://api.staifdev.codes

# Ponder/Goldsky GraphQL endpoint. When set, used as the fast path
# for dashboards and activity lists; otherwise the frontend falls
# back to reading logs directly via viem.
VITE_SUBGRAPH_URL=https://indexer.staifdev.codes

# ──────────────────────────────────────────────
# Backend (only consumed by the separate PayLink backend service).
# Listed here for a quick cross-reference when bootstrapping both.
# See ./backend-docs.md for the authoritative list.
# ──────────────────────────────────────────────
CHAIN_ID=11142220
CELO_SEPOLIA_RPC_URL=
CELO_RPC_URL=
FACTORY_ADDRESS=
SUBGRAPH_URL=
PINATA_JWT=
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
X402_RELAYER_KEY=

NODE_ENV=
HOST=
PORT=
LOG_LEVEL=

CACHE_TTL_MS=
REMINDER_CRON=

SC_ISSUER_KEY=
FEDERATED_ATTESTATIONS_ADDRESS=
